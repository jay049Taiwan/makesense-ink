  {
   "id": "cebfa382-5b52-4ab0-aa52-d93191538146",
   "name": "Parse Claude",
   "type": "n8n-nodes-base.code",
   "typeVersion": 2,
   "position": [
    1568,
    288
   ],
   "parameters": {
    "mode": "runOnceForAllItems",
    "language": "javaScript",
    "jsCode": "const resp = $input.first().json;\nconst prompt = $('Build search prompt').first().json;\nconst usage = resp.usage || {};\nconst blocks = resp.content || [];\nconst texts = blocks.filter(b => b.type === 'text').map(b => b.text);\nconst lastText = texts.length ? texts[texts.length - 1] : '';\nlet parsed;\ntry {\n  const m = lastText.match(/\\{[\\s\\S]*\\}/);\n  parsed = m ? JSON.parse(m[0]) : { execution_summary: lastText.slice(0,400), results: [] };\n} catch (e) {\n  parsed = { execution_summary: 'JSON parse failed', results: [] };\n}\nlet results = Array.isArray(parsed.results) ? parsed.results.slice(0, 20) : [];\nconst seen = new Set();\nresults = results.filter(r => {\n  const u = (r.url || '').toString().trim();\n  if (!u || seen.has(u)) return false;\n  seen.add(u); return true;\n});\nconst input_tokens = parseInt(usage.input_tokens || 0);\nconst output_tokens = parseInt(usage.output_tokens || 0);\nconst cost_usd = (input_tokens*3 + output_tokens*15)/1000000;\nconst cost_ntd = (cost_usd*32).toFixed(2);\nconst usage_line = '進=' + input_tokens + ' 出=' + output_tokens + ' 成本NT' + cost_ntd + ' (web search 另計)';\nconst count = results.length;\nconst sanitize = s => (s || '').toString()\n  .replace(/[\\/\\\\:<>#@\\[\\]\\{\\}\\|\\^\\`\\*_~\"']/g, ' ')\n  .replace(/[\\u2010-\\u2027\\u2030-\\u205E]/g, ' ')\n  .replace(/[\\uFF00-\\uFF0F\\uFF1A-\\uFF20\\uFF3B-\\uFF40\\uFF5B-\\uFF65]/g, ' ')\n  .replace(/[\\u3000-\\u3017\\u301D-\\u303F]/g, ' ')\n  .replace(/\\s+/g, ' ').trim().slice(0, 500);\nconst search_summary = (parsed.execution_summary || '') + ' | 採集 ' + count + ' 筆 | ' + usage_line;\nconst meta = { db06_id: prompt.db06_id, db05_id: prompt.db05_id, ai_mode: prompt.ai_mode, sort_num: prompt.sort_num, mingxi_name: prompt.mingxi_name, count, search_summary, safe_summary: sanitize(parsed.execution_summary || ''), usage_line, has_results: count > 0 };\nif (count === 0) {\n  return [{ json: { ...meta } }];\n}\nreturn results.map((r, i) => ({ json: {\n  ...meta,\n  r_title: (r.title || ('參考資料 ' + (i+1))).toString().slice(0, 180),\n  r_url: (r.url || '').toString().slice(0, 1800),\n  r_summary: (r.summary || '').toString().slice(0, 1500)\n}}));"
   }
  },
