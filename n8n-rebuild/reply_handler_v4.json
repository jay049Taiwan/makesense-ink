  {
   "id": "940da5dc-dccd-4f5e-af9b-0a2a2e34e46e",
   "name": "Parse Reply",
   "type": "n8n-nodes-base.code",
   "typeVersion": 2,
   "position": [
    224,
    288
   ],
   "parameters": {
    "mode": "runOnceForAllItems",
    "language": "javaScript",
    "jsCode": "const j = $input.first().json.body || $input.first().json;\nif (j.callback_query) {\n  const cq = j.callback_query;\n  const data = (cq.data || '').toString();\n  const m = data.match(/^([AB])([01A]):([a-f0-9]{32})$/);\n  if (!m) return [{ json: { valid: false, route: 'none' } }];\n  const gate = m[1]; const code = m[2]; const db06_id = m[3];\n  const chat_id = cq.message?.chat?.id || 8523155253;\n  const is_all = code === 'A';\n  const ok = code === '1' || is_all;\n  let route;\n  if (gate === 'A') route = ok ? 'gateA_go' : 'cancel';\n  else route = ok ? 'gateB_go' : 'cancel';\n  return [{ json: { valid: true, route, gate, db06_id, reply_text: '', chat_id, set_auto: is_all } }];\n}\nconst msg = j.message || j;\nconst reply_to = msg.reply_to_message;\nconst out = { valid: false, route: 'none' };\nif (!reply_to) return [{ json: out }];\nconst orig = reply_to.text || '';\nconst m2 = orig.match(/gate([AB])\\s+db06=([a-f0-9]{32})/i);\nif (!m2) return [{ json: out }];\nconst gate = m2[1].toUpperCase();\nconst db06_id = m2[2];\nconst reply_text = (msg.text || '').toString().trim();\nif (!reply_text) return [{ json: out }];\nconst chat_id = msg.chat.id;\nconst lower = reply_text.toLowerCase();\nconst approveSet = ['好','ok','同意','通過','可以','讚','y','yes'];\nconst isApprove = approveSet.includes(lower);\nconst isRedo = /redo|重跑/i.test(reply_text);\nlet route;\nif (gate === 'A') route = isApprove ? 'gateA_go' : 'gateA_modify';\nelse { if (isApprove) route = 'gateB_go'; else if (isRedo) route = 'gateB_redo'; else route = 'gateB_hint'; }\nreturn [{ json: { valid: true, route, gate, db06_id, reply_text, chat_id, set_auto: false } }];"
   }
