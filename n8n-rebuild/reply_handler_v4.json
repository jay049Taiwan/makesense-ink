   "parameters": {
    "mode": "runOnceForAllItems",
    "language": "javaScript",
    "jsCode": "const row = $input.first().json || {};\nconst j = $('Parse DB06').first().json;\nconst reply_to = parseInt(row.last_msg_id || 0) || 0;\nconst sanitize = s => (s || '').toString()\n  .replace(/[\\/\\\\:<>#@\\[\\]\\{\\}\\|\\^\\`\\*_~\"']/g, ' ')\n  .replace(/[\\u2010-\\u2027\\u2030-\\u205E]/g, ' ')\n  .replace(/[\\uFF00-\\uFF0F\\uFF1A-\\uFF20\\uFF3B-\\uFF40\\uFF5B-\\uFF65]/g, ' ')\n  .replace(/[\\u3000-\\u3017\\u301D-\\u303F]/g, ' ')\n  .replace(/\\s+/g, ' ').trim().slice(0, 1500);\nconst msg = '關卡A 執行前確認 (已更新執行構想)\\n' +\n  '第 ' + (j.sort_num != null ? j.sort_num : '?') + ' 棒 (' + sanitize(j.ai_mode) + ')\\n' +\n  'DB06 頁面 ' + j.db06_id + '\\n\\n' +\n  '更新後執行構想:\\n' + sanitize(j.reply_text) + '\\n\\n' +\n  '按 OK 放行這一關,按 OK ALL 之後全自動。要再改請打字 reply。\\n' +\n  'gateA db06=' + j.db06_id;\nreturn [{ json: { chat_id: j.chat_id, flow_id: j.db05_id, reply_to, tg_message: msg, cb_ok: 'A1:' + j.db06_id, cb_all: 'AA:' + j.db06_id } }];"
