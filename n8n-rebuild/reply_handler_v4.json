   ],
   "parameters": {
    "mode": "runOnceForAllItems",
    "language": "javaScript",
    "jsCode": "const row = $input.first().json || {};\nconst auto_mode = row.auto_mode === true;\nconst reply_to = parseInt(row.last_msg_id || 0) || 0;\nconst results = $('Query DB06 next').first().json.results || [];\nconst chat_id = $('Parse DB06').first().json.chat_id;\nconst db05_id = $('Parse DB06').first().json.db05_id;\nconst sanitize = s => (s || '').toString()\n  .replace(/[\\/\\\\:<>#@\\[\\]\\{\\}\\|\\^\\`\\*_~\"']/g, ' ')\n  .replace(/[\\u2010-\\u2027\\u2030-\\u205E]/g, ' ')\n  .replace(/[\\uFF00-\\uFF0F\\uFF1A-\\uFF20\\uFF3B-\\uFF40\\uFF5B-\\uFF65]/g, ' ')\n  .replace(/[\\u3000-\\u3017\\u301D-\\u303F]/g, ' ')\n  .replace(/\\s+/g, ' ').trim().slice(0, 1500);\nconst total = results.length;\nconst done = results.filter(p => (p.properties['ai狀態']?.status?.name||'') === '完成').length;\nconst pending = results.filter(p => (p.properties['ai狀態']?.status?.name||'') !== '完成');\nif (pending.length === 0) {\n  return [{ json: { has_next: false, auto_mode, reply_to, flow_id: db05_id, db06_id: '', chat_id, tg_message: '全套完成 共 ' + total + ' 棒已全部通過。', cb_ok: 'noop', cb_all: 'noop', runner_url: '' } }];\n}\nconst p = pending[0];\nconst db06_id = p.id.replace(/-/g, '');\nconst raw_mode = p.properties['ai模式']?.select?.name || '';\nconst ai_mode = sanitize(raw_mode);\nlet runner_url;\nif (raw_mode.includes('聯想')) runner_url = 'https://makesense.zeabur.app/webhook/db06-lianxiang-traversal';\nelse if (raw_mode.includes('搜查')) runner_url = 'https://makesense.zeabur.app/webhook/db06-search';\nelse runner_url = 'https://makesense.zeabur.app/webhook/db06-baton-runner';\nconst sort_num = p.properties['排序']?.number;\nconst exec_idea = p.properties['執行構想']?.rich_text?.map(t=>t.plain_text).join('') || '';\nconst idea_show = exec_idea ? sanitize(exec_idea) : '(執行構想為空,將用該棒預設工作指示)';\nconst base = '關卡A 執行前確認\\n' +\n  '第 ' + (sort_num != null ? sort_num : '?') + ' 棒 (' + ai_mode + ')。全套 ' + total + ' 棒,已完成 ' + done + ' 棒。\\n' +\n  'DB06 頁面 ' + db06_id + '\\n\\n' +\n  '本棒預定執行構想:\\n' + idea_show;\nconst manual_msg = base + '\\n\\n按 OK 放行這一關,按 OK ALL 之後全自動。要改執行構想 skip stop 請打字 reply。\\ngateA db06=' + db06_id;\nconst auto_msg = base + '\\n\\n[全自動模式] 自動執行本棒,免按。';\nreturn [{ json: { has_next: true, auto_mode, reply_to, flow_id: db05_id, db06_id, chat_id, runner_url, tg_message: auto_mode ? auto_msg : manual_msg, cb_ok: 'A1:' + db06_id, cb_all: 'AA:' + db06_id } }];"
   }
