    "jsCode": "const p = $input.first().json;\nconst r = $('Parse Reply').first().json;\nconst ai_mode = p.properties['ai模式']?.select?.name || '';\nlet runner_url;\nif (ai_mode.includes('聯想')) runner_url = 'https://makesense.zeabur.app/webhook/db06-lianxiang-traversal';\nelse if (ai_mode.includes('搜查')) runner_url = 'https://makesense.zeabur.app/webhook/db06-search';\nelse runner_url = 'https://makesense.zeabur.app/webhook/db06-baton-runner';\nreturn [{ json: {\n  ...r,\n  ai_mode,\n  runner_url,\n  exec_idea: p.properties['執行構想']?.rich_text?.map(t=>t.plain_text).join('') || '',\n  sort_num: p.properties['排序']?.number,\n  db05_id: (p.properties['對應內容']?.relation?.[0]?.id || '').replace(/-/g, '')\n}}];"
