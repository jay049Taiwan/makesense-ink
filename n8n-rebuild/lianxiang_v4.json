   "parameters": {
    "mode": "runOnceForAllItems",
    "language": "javaScript",
    "jsCode": "const target = $input.first().json;\nconst item = $('Parse DB06').first().json;\nconst tprops = target.properties || {};\nconst target_idea = tprops['執行構想']?.rich_text?.map(t=>t.plain_text).join('') || '';\nconst target_name = tprops['內容名稱']?.title?.map(t=>t.plain_text).join('') || '';\nconst target_theme = tprops['主題名稱']?.rich_text?.map(t=>t.plain_text).join('') || '';\nconst l1 = (tprops['對應對象']?.relation || []).map(r => r.id.replace(/-/g,''));\nconst base = { ...item, target_idea, target_name, target_theme };\nif (l1.length === 0) return [{ json: { ...base, has_l1: false, l1_id: null } }];\nreturn l1.map(id => ({ json: { ...base, has_l1: true, l1_id: id } }));"
