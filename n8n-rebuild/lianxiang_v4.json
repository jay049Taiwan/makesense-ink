  {
   "id": "86db63d0-bbac-4977-94e1-5ab97358dd75",
   "name": "Collect candidates",
   "type": "n8n-nodes-base.code",
   "typeVersion": 2,
   "position": [
    2464,
    192
   ],
   "parameters": {
    "mode": "runOnceForAllItems",
    "language": "javaScript",
    "jsCode": "const meta = $('Build pool + query').first().json;\nconst db05r = $('Query DB05').first().json.results || [];\nconst db06r = $('Query DB06').first().json.results || [];\nconst target_id = meta.db05_id;\nconst cands = [];\nconst seen = new Set();\nfor (const p of db05r) {\n  const id = p.id.replace(/-/g,'');\n  if (id === target_id || seen.has(id)) continue;\n  seen.add(id);\n  const title = p.properties['內容名稱']?.title?.map(t=>t.plain_text).join('') || '(未命名)';\n  cands.push({ id, db: 'DB05', x_field: '內容引用', title });\n}\nfor (const p of db06r) {\n  const id = p.id.replace(/-/g,'');\n  if (seen.has(id)) continue;\n  seen.add(id);\n  const title = p.properties['明細名稱']?.title?.map(t=>t.plain_text).join('') || '(未命名)';\n  cands.push({ id, db: 'DB06', x_field: '明細引用', title });\n}\nconst capped = cands.slice(0, 30);\nif (capped.length === 0) {\n  return [{ json: { ...meta, has_cand: false, cand_count: 0 } }];\n}\nreturn capped.map((c, i) => ({ json: { ...meta, has_cand: true, cand_count: capped.length, c_num: i+1, c_id: c.id, c_db: c.db, c_xfield: c.x_field, c_title: c.title } }));"
   }
  },
