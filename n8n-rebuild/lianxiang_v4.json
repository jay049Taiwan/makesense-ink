  {
   "id": "4534ece5-b1cd-4190-9ce5-9a327c2c4c4d",
   "name": "Build judge prompt",
   "type": "n8n-nodes-base.code",
   "typeVersion": 2,
   "position": [
    2912,
    96
   ],
   "parameters": {
    "mode": "runOnceForAllItems",
    "language": "javaScript",
    "jsCode": "const cands = $('Collect candidates').all().map(i => i.json);\nconst meta = cands[0];\nconst listText = cands.map(c => c.c_num + '. [' + c.c_db + '] ' + c.c_title).join('\\n');\nconst system = '你是 makesense 嗨嗨家族的聯想棒判斷層。你的核心能力是跨類資料引用的語意把關。n8n 已用標籤 traversal 撈出一批候選 page,你要逐筆判斷「這筆候選跟 target 內容是否真的相關、值得被引用為參考」,避免無腦把所有共標籤的東西都連進來。\\n\\n判斷原則:\\n1. 主題、事件、人物、地點實際相關才留;只是剛好共用一個廣泛標籤但內容無關的,剔除。\\n2. 寧缺勿濫,只留真正有引用價值的。\\n3. 回 JSON,最後一個區塊只有 JSON:\\n{\"hits\": [命中的候選編號數字], \"execution_summary\": \"判斷了幾筆、留幾筆、剔除原因摘要\"}';\nconst user = 'target 內容\\n名稱 ' + meta.target_name + '\\n主題 ' + meta.target_theme + '\\n執行構想\\n' + (meta.target_idea || '(空)') + '\\n\\n候選清單(編號 DB 標題)\\n' + listText + '\\n\\n請逐筆判斷哪些候選真的跟 target 相關值得引用,回 JSON。';\nreturn [{ json: { system, user, db06_id: meta.db06_id, db05_id: meta.db05_id, ai_mode: meta.ai_mode, sort_num: meta.sort_num, cand_count: meta.cand_count } }];"
   }
  },
  {
   "id": "b9feeac4-c6d3-474c-b5a6-f803d8796378",
   "name": "Claude judge",
   "type": "n8n-nodes-base.httpRequest",
   "typeVersion": 4.3,
   "position": [
    3136,
    96
   ],
   "parameters": {
    "method": "POST",
    "url": "https://api.anthropic.com/v1/messages",
    "sendHeaders": true,
    "headerParameters": {
     "parameters": [
      {
       "name": "x-api-key",
       "value": "={{ $env.ANTHROPIC_API_KEY }}"
      },
      {
       "name": "anthropic-version",
       "value": "2023-06-01"
      },
      {
       "name": "Content-Type",
       "value": "application/json"
      }
     ]
    },
    "sendBody": true,
    "specifyBody": "json",
    "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 2048,\n  \"system\": {{ JSON.stringify($json.system) }},\n  \"messages\": [{ \"role\": \"user\", \"content\": {{ JSON.stringify($json.user) }} }]\n}"
   }
  },
  {
   "id": "12e1412d-571e-42bd-869b-341481a72d75",
   "name": "Parse judge",
   "type": "n8n-nodes-base.code",
   "typeVersion": 2,
   "position": [
    3360,
    96
   ],
   "parameters": {
    "mode": "runOnceForAllItems",
    "language": "javaScript",
    "jsCode": "const resp = $input.first().json;\nconst prompt = $('Build judge prompt').first().json;\nconst cands = $('Collect candidates').all().map(i => i.json);\nconst usage = resp.usage || {};\nconst text = resp.content?.[0]?.text || '';\nlet parsed;\ntry { const m = text.match(/\\{[\\s\\S]*\\}/); parsed = m ? JSON.parse(m[0]) : { hits: [], execution_summary: text.slice(0,300) }; }\ncatch(e) { parsed = { hits: [], execution_summary: 'JSON parse failed' }; }\nconst hitNums = Array.isArray(parsed.hits) ? parsed.hits.map(n => parseInt(n)) : [];\nconst db05_hits = [];\nconst db06_hits = [];\nfor (const c of cands) {\n  if (!hitNums.includes(c.c_num)) continue;\n  if (c.c_xfield === '內容引用') db05_hits.push(c.c_id);\n  else if (c.c_xfield === '明細引用') db06_hits.push(c.c_id);\n}\nconst input_tokens = parseInt(usage.input_tokens||0);\nconst output_tokens = parseInt(usage.output_tokens||0);\nconst cost_ntd = ((input_tokens*3 + output_tokens*15)/1000000*32).toFixed(2);\nconst sanitize = s => (s||'').toString().replace(/[\\/\\\\:<>#@\\[\\]\\{\\}\\|\\^\\`\\*_~\"']/g,' ').replace(/[\\u2010-\\u2027\\u2030-\\u205E]/g,' ').replace(/[\\uFF00-\\uFF0F\\uFF1A-\\uFF20\\uFF3B-\\uFF40\\uFF5B-\\uFF65]/g,' ').replace(/[\\u3000-\\u3017\\u301D-\\u303F]/g,' ').replace(/\\s+/g,' ').trim().slice(0,400);\nconst summary = '聯想棒 hybrid 完成。候選 ' + cands.length + ' 筆,Claude 判定命中 ' + (db05_hits.length+db06_hits.length) + ' 筆(內容引用 ' + db05_hits.length + ',明細引用 ' + db06_hits.length + ')。' + sanitize(parsed.execution_summary||'');\nlet props = {};\nif (db05_hits.length > 0) props['內容引用'] = { relation: db05_hits.map(id=>({id})) };\nif (db06_hits.length > 0) props['明細引用'] = { relation: db06_hits.map(id=>({id})) };\nreturn [{ json: { db06_id: prompt.db06_id, db05_id: prompt.db05_id, ai_mode: prompt.ai_mode, sort_num: prompt.sort_num, hit_count: db05_hits.length+db06_hits.length, summary, target_props: props, has_props: Object.keys(props).length>0, usage_line: '進=' + input_tokens + ' 出=' + output_tokens + ' 成本NT' + cost_ntd } }];"
   }
  },
