  {
   "id": "8c0ceaa4-e00a-4d98-a957-4b82ead3f866",
   "name": "Build pool + query",
   "type": "n8n-nodes-base.code",
   "typeVersion": 2,
   "position": [
    1792,
    192
   ],
   "parameters": {
    "mode": "runOnceForAllItems",
    "language": "javaScript",
    "jsCode": "const l1items = $('Extract Layer1').all();\nconst layer1 = l1items.map(i => i.json.l1_id).filter(Boolean);\nconst fetched = $('Fetch DB08').all();\nlet layer2 = [];\nfor (const f of fetched) {\n  const rel = f.json.properties?.['自對標籤']?.relation || [];\n  layer2 = layer2.concat(rel.map(r => r.id.replace(/-/g,'')));\n}\nconst pool = [...new Set([...layer1, ...layer2])];\nconst base = l1items[0].json;\nconst db05_or = pool.map(t => ({ property: '對應對象', relation: { contains: t } }));\nconst db06_or = pool.map(t => ({ property: '對應標籤對象', relation: { contains: t } }));\nreturn [{ json: {\n  db06_id: base.db06_id, db05_id: base.db05_id, ai_mode: base.ai_mode, mingxi_name: base.mingxi_name, sort_num: base.sort_num,\n  target_idea: base.target_idea, target_name: base.target_name, target_theme: base.target_theme,\n  layer1_count: layer1.length, layer2_count: layer2.length, pool_count: pool.length,\n  db05_query_body: JSON.stringify({ filter: { or: db05_or }, page_size: 40 }),\n  db06_query_body: JSON.stringify({ filter: { or: db06_or }, page_size: 40 })\n}}];"
   }
  },
