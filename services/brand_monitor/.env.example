# brand_monitor 環境變數 — 部署到 Zeabur 時在面板逐項填入
# 本機開發：複製成 .env 後填值（.env 已被 .gitignore 排除，不會進版控）
# 命名與 makesense n8n 服務對齊，可直接共用同一份值

# === Notion ===
# Notion integration token，需對 DB01 / DB05 / DB06 / DB08 開啟存取權
NOTION_INTEGRATION_TOKEN=

# === Anthropic API（AI 相關度評估）===
ANTHROPIC_API_KEY=

# === Telegram 通知 ===
TELEGRAM_BOT_TOKEN=
NOAH_TG_USER_ID=8523155253

# === 狀態檔目錄 ===
# Zeabur 需掛 Volume 到此路徑，否則重啟後輿情比對的 hash 會失憶
STATE_DIR=/app/state

# === Cloudflare R2（選用：標案附件上傳；任一未填則略過上傳）===
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
# 公開存取網址前綴（pub-xxxxxxxx.r2.dev 或自訂網域）；未填則上傳完不回傳公開連結
R2_PUBLIC_BASE_URL=
