# brand_monitor 環境變數 — 部署到 Zeabur 時在面板逐項填入
# 本機開發：複製成 .env 後填值（.env 已被 .gitignore 排除，不會進版控）

# === Notion ===
# Notion integration token，需對 DB01 / DB05 / DB06 / DB08 開啟存取權
NOTION_API_KEY=

# === Claude API（AI 相關度評估）===
CLAUDE_API_KEY=

# === Telegram 通知 ===
TELEGRAM_BOT_TOKEN=
NOAH_TG_USER_ID=8523155253

# === 狀態檔目錄 ===
# Zeabur 需掛 Volume 到此路徑，否則重啟後輿情比對的 hash 會失憶
STATE_DIR=/app/state

# === Cloudinary（選用：標案附件上傳；留空則略過上傳）===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
